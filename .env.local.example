NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
# If your Supabase project uses publishable keys instead of anon keys, use this:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"

# AI provider keys are NOT set in this file. The ai-coach / generate-plan
# Supabase Edge Functions read them from Supabase secrets, not from this
# Next.js app's environment. Set them with the Supabase CLI:
#   supabase secrets set OPENROUTER_API_KEY="sk-or-..."      # preferred provider
#   supabase secrets set GEMINI_API_KEY="YOUR_GOOGLE_AI_STUDIO_KEY"  # fallback if OpenRouter isn't set
#
# The model used per-request comes from user_settings.ai_model (editable in
# Settings), defaulting to "google/gemini-2.5-flash" (an OpenRouter model id).
# Until a key is set, the AI coach and plan generator return a clear 503
# error instead of crashing.
