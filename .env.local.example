NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
# If your Supabase project uses publishable keys instead of anon keys, use this:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"

# Server-only. Do not expose this in browser code.
# For Supabase Edge Functions, set it with:
# supabase secrets set GEMINI_API_KEY="YOUR_GOOGLE_AI_STUDIO_KEY"
# supabase secrets set GEMINI_MODEL="gemini-2.5-flash"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
